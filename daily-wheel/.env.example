# Daily Wheel — variables d'environnement (gabarit ; copier vers .env.local et renseigner).
# .env.local n'est JAMAIS commité. Ce fichier .env.example l'est (valeurs factices uniquement).

# --- Côté CLIENT (publiques, livrées au navigateur) ---
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<clé anon / publishable>

# --- Côté SERVEUR uniquement (SENSIBLE — jamais NEXT_PUBLIC_, jamais commité) ---
SUPABASE_SECRET_KEY=<clé service_role / sb_secret_...>

# --- Migration : chaîne de connexion Postgres pour `supabase db push --db-url` (sans login/link) ---
# Dashboard → Project Settings → Database → Connection string → URI (Session pooler de préférence).
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
